# Copy this file to .env and fill in the real values.
# Never commit .env to version control.

# Telegram bot token obtained from @BotFather
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID(s) of barber Telegram accounts (comma-separated for multiple barbers).
# The first ID is the primary barber who receives booking notifications.
# Each barber can get their ID by messaging @userinfobot.
BARBER_CHAT_ID=987654321,123456789

# Mini App mode (developer toggle).
# Set MINIAPP_ENABLED=true to activate WebApp button instead of regular bot flow.
# MINIAPP_URL must also be set to a valid HTTPS URL.
# Restart the bot after changing these values.
MINIAPP_ENABLED=false
MINIAPP_URL=https://yourdomain.com/
